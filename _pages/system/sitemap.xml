---
layout: null
permalink: /sitemap.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url><loc>{{ '/' | absolute_url }}</loc></url>
  <url><loc>{{ '/pond/' | absolute_url }}</loc></url>
  <url><loc>{{ '/search/' | absolute_url }}</loc></url>
  <url><loc>{{ '/quacks/' | absolute_url }}</loc></url>
  <url><loc>{{ '/projects/' | absolute_url }}</loc></url>
  <url><loc>{{ '/certifications/' | absolute_url }}</loc></url>
  <url><loc>{{ '/achievements/' | absolute_url }}</loc></url>
  {% assign sitemap_items = site.quacks | concat: site.ctf | concat: site.projects | concat: site.certifications | concat: site.achievements | concat: site.tools | concat: site.books %}
  {% for item in sitemap_items %}
  <url>
    <loc>{{ item.url | absolute_url }}</loc>
    {% if item.date %}<lastmod>{{ item.date | date_to_xmlschema }}</lastmod>{% endif %}
  </url>
  {% endfor %}
</urlset>
